# ESS environment configuration
# Copy this to config/.env and fill in real values.
# Never commit config/.env to source control.

# ─────────────────────────────────────────────────────────────
# LLM — AWS Bedrock (ABSK bearer token format)
# ─────────────────────────────────────────────────────────────
# Encode as: ABSK + base64(AWS_ACCESS_KEY_ID:AWS_SECRET_ACCESS_KEY)
AWS_BEARER_TOKEN_BEDROCK=ABSKreplace_with_real_token
AWS_BEDROCK_REGION=us-west-2

# ─────────────────────────────────────────────────────────────
# Datadog — consumed by the Pup CLI binary at runtime
# ─────────────────────────────────────────────────────────────
DD_API_KEY=replace_with_datadog_api_key
DD_APP_KEY=replace_with_datadog_app_key
DD_SITE=app.datadoghq.com
PUP_MAX_CONCURRENT=10
PUP_DEFAULT_TIMEOUT=60

# ─────────────────────────────────────────────────────────────
# Sentry (self-hosted)
# ─────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=replace_with_sentry_auth_token
SENTRY_HOST=sentry.example.com
SENTRY_ORG=example

# ─────────────────────────────────────────────────────────────
# Log Scout — remote syslog-side search agent
# ─────────────────────────────────────────────────────────────
DEFAULT_LOG_SCOUT_URL=http://syslog.example.com:8090

# ─────────────────────────────────────────────────────────────
# Monitoring defaults
# ─────────────────────────────────────────────────────────────
DEFAULT_MONITORING_WINDOW_MINUTES=30
DEFAULT_CHECK_INTERVAL_MINUTES=5
MAX_MONITORING_WINDOW_MINUTES=120
MAX_CONCURRENT_SESSIONS=20

# ─────────────────────────────────────────────────────────────
# MS Teams
# ─────────────────────────────────────────────────────────────
# DEFAULT_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
